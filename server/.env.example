# ===== Learnity Server Environment Variables =====
# Copy this file to ".env" and fill in your real values.

# Server
PORT=4000

# Frontend origin (used for CORS + email links)
CORS_ORIGIN=http://localhost:3000

# MongoDB Atlas connection string
# Get it from https://cloud.mongodb.com -> Connect -> Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/learnity?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# Default admin account (auto-created on server startup)
ADMIN_EMAIL=admin@learnity.local
ADMIN_PASSWORD=Admin@123

# Cloudinary (media uploads)
CLOUD_NAME=your_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
FOLDER_NAME=Learnity

# File storage: "local" (default, saves to server/uploads) or "cloudinary".
STORAGE=local
SERVER_URL=http://localhost:4000

# Mail (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Dev/demo only: expose the OTP in the API response + on the website so signup
# works without a real mail server. Set to false in production.
EXPOSE_OTP=true

# Razorpay (payments)
RAZORPAY_KEY=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_key_secret
